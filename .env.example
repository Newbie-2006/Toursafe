# =========================================================
# TourSafe — Environment Variables (ALL OPTIONAL)
# =========================================================
# TourSafe is BYOK (Bring Your Own API Key). You can run and deploy the app
# with NONE of these set, then configure everything from the in-app UI at:
#   Settings -> AI Configuration   (Gemini key + model)
#   Settings -> Maps Configuration (Google Maps key)
#   Settings -> Supabase           (URL + anon key)
#
# These env vars are only OPTIONAL defaults / fallbacks. Nothing here is
# required for the app to build, deploy, or function.
# Never commit real keys. Copy this file to `.env.local` for local defaults.
# =========================================================

# ---- Supabase (optional) ----
# Get these from https://supabase.com -> Project -> Settings -> API
# If omitted, the app runs in LOCAL DEMO MODE (browser storage, no server DB).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Google Maps (REQUIRED for the live map) ----
# Get from https://console.cloud.google.com -> APIs & Services -> Credentials
# Enable: "Maps JavaScript API", "Places API", and "Directions API".
# The Maps JS loader reads ONLY this build-time env var (not Settings/BYOK) —
# a runtime-changing key breaks the Google Maps loader singleton. Set it here,
# then restart `next dev` (env changes require a restart to take effect).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# ---- Google Gemini (optional default) ----
# Get from https://aistudio.google.com/app/apikey
# Preferred: enter it at runtime in Settings -> AI Configuration (BYOK).
# This server-side var is only a fallback if a request arrives with no key.
GEMINI_API_KEY=

# ---- App ----
NEXT_PUBLIC_APP_NAME=TourSafe
